{
  "name": "gather-apple-music-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local macOS daemon: Apple Music now-playing zu Gather-Status",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit",
    "test:sink": "tsx scripts/test-sink.ts"
  },
  "dependencies": {
    "@gathertown/gather-game-client": "^43.0.1",
    "dotenv": "^17.4.2",
    "isomorphic-ws": "^5.0.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3"
  }
}
