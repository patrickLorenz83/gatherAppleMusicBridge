{
  "name": "gather-apple-music-bridge",
  "version": "0.1.0",
  "description": "Local macOS daemon that pushes Apple Music now-playing tracks to your Gather 2.0 custom status via Chrome DevTools Protocol.",
  "type": "module",
  "license": "MIT",
  "author": "Patrick Lorenz",
  "homepage": "https://github.com/patricklorenz/gatherAppleMusicBridge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patricklorenz/gatherAppleMusicBridge.git"
  },
  "bugs": {
    "url": "https://github.com/patricklorenz/gatherAppleMusicBridge/issues"
  },
  "keywords": [
    "macos",
    "apple-music",
    "gather",
    "gather-town",
    "now-playing",
    "status",
    "launchd",
    "applescript",
    "chrome-devtools-protocol",
    "cdp",
    "electron"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p . --noEmit",
    "test": "tsx scripts/lib/plist.test.ts",
    "test:sink": "tsx scripts/test-sink.ts",
    "test:sources": "tsx scripts/test-sources.ts",
    "check-cdp": "tsx scripts/check-cdp.ts",
    "install-daemon": "tsx scripts/install-daemon.ts",
    "uninstall-daemon": "tsx scripts/uninstall-daemon.ts"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.3",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "run-applescript": "^7.1.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22.19.18",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3"
  }
}
