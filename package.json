{
  "name": "gather-apple-music-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local macOS daemon: Apple Music now-playing zu Gather-Status",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "tsc -p . --noEmit",
    "test:sink": "tsx scripts/test-sink.ts",
    "test:sources": "tsx scripts/test-sources.ts",
    "check-cdp": "tsx scripts/check-cdp.ts",
    "install-daemon": "tsx scripts/install-daemon.ts",
    "uninstall-daemon": "tsx scripts/uninstall-daemon.ts"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.3",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "run-applescript": "^7.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^22.19.18",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3"
  }
}
